<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Summit Finder</title>
  <meta name="theme-color" content="#020617" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Summit Finder" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="manifest" href="manifest.webmanifest" />
  <link rel="apple-touch-icon" href="icons/icon-192.png" />
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="brand">
        <div class="logo">▲</div>
        <div>
          <h1>Summit Finder</h1>
          <p>Phone browser prototype</p>
        </div>
      </div>
      <nav>
        <button class="nav active" data-tab="discover">Discover</button>
        <button class="nav" data-tab="map">Map</button>
        <button class="nav" data-tab="weekend">Weekend</button>
        <button class="nav" data-tab="favorites">Favorites</button>
        <button class="nav" data-tab="settings">Settings</button>
      </nav>
      <div class="note">
        <strong>Build path</strong>
        <p>Prototype first. Production can be built as WinUI 3, .NET MAUI, Electron, or Tauri with an Azure backend.</p>
      </div>
    </aside>

    <main>
      <section id="discover" class="tab active-tab">
        <div class="layout-three">
          <section class="panel filters">
            <h2>Find me a mountain</h2>
            <p class="muted">Filter by summit height, wind and weather.</p>

            <label>Minimum height</label>
            <select id="minHeight"></select>

            <label>Search radius</label>
            <select id="radius">
              <option value="25">25 km</option>
              <option value="50">50 km</option>
              <option value="100">100 km</option>
              <option value="200">200 km</option>
              <option value="500" selected>500 km</option>
            </select>

            <label>Maximum wind</label>
            <select id="maxWind">
              <option>10</option><option>20</option><option>30</option><option>40</option><option selected>50</option><option>60</option><option>80</option><option>100</option>
            </select>

            <label>Max precipitation</label>
            <select id="maxPrecip">
              <option>0</option><option>1</option><option>2</option><option selected>5</option><option>10</option>
            </select>

            <label>Weather conditions</label>
            <div id="weatherChips" class="chips"></div>

            <button id="searchBtn" class="primary">Search mountains</button>
          </section>

          <section class="results">
            <div class="section-head">
              <div>
                <h2>Best matches</h2>
                <p id="resultCount" class="muted"></p>
              </div>
              <select id="sortBy">
                <option value="score">Best score</option>
                <option value="distance">Closest</option>
                <option value="wind">Lowest wind</option>
                <option value="height">Highest</option>
              </select>
            </div>
            <div id="cards"></div>
          </section>

          <section id="detail" class="panel detail empty">
            <div class="empty-state">Select a mountain to view details.</div>
          </section>
        </div>
      </section>

      <section id="map" class="tab">
        <div class="layout-two">
          <div class="map panel">
            <div class="map-label">
              <strong>Map prototype</strong>
              <span>Production: Map control, current location, long-press pin, colored summit pins.</span>
            </div>
            <div id="mapPins"></div>
            <div class="map-actions">
              <button class="primary">Use current location</button>
              <button>Search around selected pin</button>
            </div>
          </div>
          <section id="mapDetail" class="panel detail empty">
            <div class="empty-state">Click a map pin.</div>
          </section>
        </div>
      </section>

      <section id="weekend" class="tab">
        <h2>Weekend Finder</h2>
        <p class="muted">Best ranked mountain options for Saturday and Sunday.</p>
        <div id="weekendGrid" class="weekend-grid"></div>
      </section>

      <section id="favorites" class="tab">
        <h2>Favorites</h2>
        <p class="muted">Saved mountains and future alert rules.</p>
        <div id="favoriteCards" class="cards-grid"></div>
      </section>

      <section id="settings" class="tab">
        <h2>Settings</h2>
        <div class="settings-list">
          <div class="panel"><h3>Units</h3><p>Default: Celsius, kilometres, km/h. Add mph in production.</p></div>
          <div class="panel"><h3>Notifications</h3><p>Alert when a favorite mountain reaches score above 90 or wind drops below 20 km/h.</p></div>
          <div class="panel"><h3>Backend</h3><p>Option A: Azure API with forecast cache, scoring service and notification engine.</p></div>
          <div class="panel"><h3>Data source</h3><p>Use official/licensed mountain-top forecast data. Do not scrape directly in the desktop app.</p></div>
        </div>
      </section>
    </main>
  </div>
  <script src="app.js"></script>
  <script>
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", () => {
        navigator.serviceWorker.register("service-worker.js").catch(console.error);
      });
    }
  </script>
</body>
</html>
